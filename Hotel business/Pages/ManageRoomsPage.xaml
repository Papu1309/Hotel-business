<Page x:Class="Hotel_business.Pages.ManageRoomsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Hotel_business.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ManageRoomsPage" Background="{StaticResource BackgroundColor}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление номерами" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5"/>

        <ListView x:Name="lvRooms" Grid.Row="1" Margin="5" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Номер" Width="80" DisplayMemberBinding="{Binding RoomNumber}"/>
                    <GridViewColumn Header="Тип" Width="150" DisplayMemberBinding="{Binding Type}"/>
                    <GridViewColumn Header="Цена за ночь" Width="120" DisplayMemberBinding="{Binding PricePerNight, StringFormat={}{0:C}}"/>
                    <GridViewColumn Header="Статус" Width="100" DisplayMemberBinding="{Binding Status}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button Content="Добавить" Click="BtnAdd_Click"/>
            <Button Content="Изменить статус" Click="BtnChangeStatus_Click"/>
            <Button Content="Удалить" Click="BtnDelete_Click" Background="{StaticResource ErrorColor}"/>
            <Button Content="Назад" Click="BtnBack_Click" Background="{StaticResource PrimaryColor}"/>
        </StackPanel>
    </Grid>
</Page>
