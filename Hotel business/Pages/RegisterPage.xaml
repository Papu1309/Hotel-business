<Page x:Class="Hotel_business.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Hotel_business.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage" Background="{StaticResource BackgroundColor}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
            <TextBlock Text="Регистрация" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="{StaticResource PrimaryColor}"/>
            <TextBlock Text="Логин"></TextBlock>
            <TextBox x:Name="txtLogin" />
            <TextBlock Text="Пароль"></TextBlock>
            <PasswordBox x:Name="txtPassword" />
            <TextBlock Text="Подтвердите пароль"></TextBlock>
            <PasswordBox x:Name="txtConfirmPassword" />
            <Button Content="Зарегистрироваться" Click="BtnRegister_Click"/>
            <Button Content="Назад к входу" Click="BtnBack_Click" Background="{StaticResource PrimaryColor}"/>
            <TextBlock x:Name="lblError" Foreground="{StaticResource ErrorColor}" TextWrapping="Wrap" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
