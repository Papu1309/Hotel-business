<Page x:Class="Hotel_business.Pages.BookingServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Hotel_business.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookingServicesPage" Background="{StaticResource BackgroundColor}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Дополнительные услуги" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5"/>

        <ListView x:Name="lvServices" Grid.Row="1" Margin="5">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Услуга" Width="200" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Описание" Width="250" DisplayMemberBinding="{Binding Description}"/>
                    <GridViewColumn Header="Цена" Width="100" DisplayMemberBinding="{Binding Price, StringFormat={}{0:C}}"/>
                    <GridViewColumn Header="Количество" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding SelectedQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button Content="Далее" Click="BtnNext_Click" Width="100"/>
            <Button Content="Назад" Click="BtnBack_Click" Background="{StaticResource PrimaryColor}" Width="100"/>
        </StackPanel>
    </Grid>
</Page>
