<Page x:Class="Hotel_business.Pages.UserMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Hotel_business.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserMainPage" Background="{StaticResource BackgroundColor}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Добро пожаловать, гость!" FontSize="24" Margin="0,0,0,30" Foreground="{StaticResource PrimaryColor}"/>
            <Button Content="Доступные номера" Width="200" Height="40" Click="BtnAvailableRooms_Click"/>
            <Button Content="Мои бронирования" Width="200" Height="40" Click="BtnMyBookings_Click"/>
            <Button Content="История платежей" Width="200" Height="40" Click="BtnPaymentHistory_Click"/>
            <Button Content="Профиль" Width="200" Height="40" Click="BtnProfile_Click"/>
            <Button Content="Выход" Width="200" Height="40" Click="BtnLogout_Click" Background="{StaticResource PrimaryColor}"/>
        </StackPanel>
    </Grid>
</Page>
