<Page x:Class="Hotel_business.Pages.PaymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Hotel_business.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PaymentPage" Background="{StaticResource BackgroundColor}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
            <TextBlock Text="Оплата бронирования" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="{StaticResource PrimaryColor}"/>
            <TextBlock Text="Сумма к оплате:" FontSize="16"/>
            <TextBlock x:Name="txtAmount" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="5"/>
            <TextBlock Text="Выберите способ оплаты:" Margin="0,20,0,5"/>
            <RadioButton x:Name="rbCash" Content="Наличные" GroupName="PaymentMethod" IsChecked="True"/>
            <RadioButton x:Name="rbCard" Content="Банковская карта" GroupName="PaymentMethod"/>
            <Button Content="Оплатить" x:Name="BtnPay" Click="BtnPay_Click" Width="200" Margin="10"/>
            <Button Content="Отмена" x:Name="BtnCancel" Click="BtnCancel_Click" Background="{StaticResource PrimaryColor}" Width="200"/>
            <TextBlock x:Name="lblError" Foreground="{StaticResource ErrorColor}" TextWrapping="Wrap" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
