<Page x:Class="Hotel_business.Pages.AdminMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Hotel_business.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminMainPage" Background="{StaticResource BackgroundColor}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Панель администратора" FontSize="24" Margin="0,0,0,30" Foreground="{StaticResource PrimaryColor}"/>
            <Button Content="Управление номерами" Width="200" Height="40" Click="BtnManageRooms_Click"/>
            <Button Content="Управление бронированиями" Width="200" Height="40" Click="BtnManageBookings_Click"/>
            <Button Content="Статистика" Width="200" Height="40" Click="BtnStatistics_Click"/>
            <Button Content="Выход" Width="200" Height="40" Click="BtnLogout_Click" Background="{StaticResource PrimaryColor}"/>
            
        </StackPanel>
    </Grid>
</Page>
