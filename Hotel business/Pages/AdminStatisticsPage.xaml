<Page x:Class="Hotel_business.Pages.AdminStatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Hotel_business.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminStatisticsPage" Background="{StaticResource BackgroundColor}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Статистика отеля" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="5"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
            <TextBlock Text="Период: " VerticalAlignment="Center"/>
            <DatePicker x:Name="dpStart" Margin="5"/>
            <TextBlock Text=" - " VerticalAlignment="Center"/>
            <DatePicker x:Name="dpEnd" Margin="5"/>
            <Button Content="Обновить" Click="BtnRefresh_Click" Width="80"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource PrimaryColor}" BorderThickness="1" Margin="5" Padding="10">
            <StackPanel>
                <TextBlock Text="Общая информация" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock x:Name="txtTotalBookings" Text="Всего бронирований: 0"/>
                <TextBlock x:Name="txtTotalRevenue" Text="Общий доход: 0"/>
                <TextBlock x:Name="txtAvgOccupancy" Text="Средняя загрузка номеров: 0%"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource PrimaryColor}" BorderThickness="1" Margin="5" Padding="10">
            <StackPanel>
                <TextBlock Text="По типам номеров" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <ListView x:Name="lvStatsByRoomType" Height="150">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Тип номера" Width="120" DisplayMemberBinding="{Binding RoomType}"/>
                            <GridViewColumn Header="Количество бронирований" Width="150" DisplayMemberBinding="{Binding Count}"/>
                            <GridViewColumn Header="Доход" Width="120" DisplayMemberBinding="{Binding Revenue, StringFormat={}{0:C}}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>

        <Button Content="Назад" Grid.Row="5" Width="100" HorizontalAlignment="Center" Click="BtnBack_Click" Background="{StaticResource PrimaryColor}" Margin="5"/>
    </Grid>
</Page>
