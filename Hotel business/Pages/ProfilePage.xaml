<Page x:Class="Hotel_business.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Hotel_business.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage" Background="{StaticResource BackgroundColor}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
            <TextBlock Text="Мой профиль" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="{StaticResource PrimaryColor}"/>

            <TextBlock Text="Логин:" Margin="0,5"/>
            <TextBox x:Name="txtLogin" IsReadOnly="True" Background="#f0f0f0"/>

            <TextBlock Text="Новый пароль (оставьте пустым, если не хотите менять):" Margin="0,10,0,5" TextWrapping="Wrap"/>
            <PasswordBox x:Name="txtNewPassword"/>

            <TextBlock Text="Подтвердите новый пароль:" Margin="0,5"/>
            <PasswordBox x:Name="txtConfirmPassword"/>

            <Button Content="Сохранить изменения" Click="BtnSave_Click" Margin="0,20"/>
            <Button Content="Назад" Click="BtnBack_Click" Background="{StaticResource PrimaryColor}"/>

            <TextBlock x:Name="lblMessage" Foreground="{StaticResource ErrorColor}" TextWrapping="Wrap" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
